# Rich Chat Environment Configuration
# rich_chat 环境变量配置

# Copy this file to .env and update the values
# 复制此文件到 .env 并更新值

# Database Configuration / 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=admin
DB_PASSWORD=password
DB_NAME=rich_chat

# Connection Pool Settings / 连接池设置
DB_MAX_CONNECTIONS=25
DB_MIN_CONNECTIONS=5
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m

# Server Configuration / 服务器配置
SERVER_PORT=:2316
SERVER_VERSION=1.0.0

# Authentication / 认证
API_AUTH_USERNAME=admin
API_AUTH_PASSWORD=password

# JWT Configuration (for future use) / JWT 配置（未来使用）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h

# Redis Configuration (for future use) / Redis 配置（未来使用）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Logging / 日志
LOG_LEVEL=info
LOG_FORMAT=text
