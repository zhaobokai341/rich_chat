# Rich Chat Server Configuration
# Copy this file to .env and modify the values for your environment

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production-min-32-chars

# HTTP Basic Auth
AUTH_USERNAME=admin
AUTH_PASSWORD=change-this-password-to-strong-one

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=123456
DB_NAME=rich_chat
DB_SSL=require

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=5350
REDIS_PASSWORD=123456
REDIS_DB=0
